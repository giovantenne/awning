# Environment (contains passwords)
.env
.env.test

# Generated configs (created from templates by setup)
configs/bitcoin.conf
configs/lnd.conf
configs/electrs.toml
configs/torrc

# Build logs
.build.log

# Runtime lock file
.lock

# Runtime data
data/bitcoin/*
!data/bitcoin/.gitkeep

data/lnd/*
!data/lnd/.gitkeep

data/electrs/*
!data/electrs/.gitkeep

data/tor/*
!data/tor/.gitkeep

data/scb/*
!data/scb/.gitkeep

data/rtl/*
!data/rtl/.gitkeep

# Generated configs (RTL)
configs/rtl.conf

# OpenCode session data
.opencode/
